{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "https://sheshi.local",
    "Audience": "sheshi-web",
    "SigningKey": "local_dev_signing_key_change_me_min_32_bytes",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Proxy": {
    "TrustForwardedHeaders": false,
    "TrustedCidr": "172.16.0.0/12"
  },
  "RateLimits": {
    "Auth": { "PermitLimit": 15, "WindowSeconds": 60 },
    "AuthAccount": { "PermitLimit": 5, "WindowSeconds": 60 },
    "Reads": { "PermitLimit": 100, "WindowSeconds": 60 }
  }
}
