    {
      "id": "review::.::holistic::test_strategy::frontend_has_no_test_harness",
      "confidence": "high",
      "detector": "review",
      "file": ".",
      "summary": "Frontend-critical API, auth, realtime, route, and component behavior has no automated test harness",
      "detail": {
        "holistic": true,
        "dimension": "test_strategy",
        "related_files": [
          "package.json",
          "src/lib/api-client.ts",
          "src/lib/sheshi.ts",
          "src/hooks/use-auth.ts",
          "src/lib/realtime.ts",
          "src/components/Composer.tsx",
          "src/components/MessageCard.tsx",
          "src/routes/tema.$messageId.tsx",
          "src/routes/index.tsx",
          "src/routes/moderim.tsx",
          "src/routes/dhoma.$slug.tsx"
        ],
        "evidence": [
          "package.json defines dev/build/lint/format but no test script and has no frontend test dependencies such as Vitest, Testing Library, Playwright, or Jest.",
          "src/lib/api-client.ts implements token injection, 401 refresh/retry, token clearing on refresh failure, JSON/form request helpers, and ApiError conversion without tests.",
          "src/lib/sheshi.ts translates backend status/error payloads into UI-facing errors like UNAUTH, EMPTY, and TOO_LONG and switches between JSON and multipart posting, but there are no tests asserting those client contracts.",
          "src/hooks/use-auth.ts owns global auth state through useSyncExternalStore, token subscriptions, and async /api/me loading, but no tests verify initialization, sign-out, refresh, or invalid-token behavior.",
          "src/components/Composer.tsx and src/components/MessageCard.tsx contain validation, image constraints, imperative prefill/focus behavior, optimistic voting rollback, delete/report gates, and keyboard submit behavior with no component tests.",
          "src/routes/tema.$messageId.tsx wires getThread, listRooms, SignalR changed handlers, JoinThread/LeaveThread, sessionStorage reply intent, nested reply rendering, collapse state, and scroll behavior with no route-level or integration test."
        ],
        "suggestion": "Add a frontend test setup and start with a small contract-focused suite: Vitest unit tests for api-client/sheshi/token-store/use-auth, React Testing Library tests for Composer and MessageCard user flows, and one route/integration test around thread reload/realtime subscription behavior. Add an npm test script so these run alongside lint/build.",
        "reasoning": "",
        "summary_hash": "f924a6ab"
      },
      "status": "open",
      "kind": "issue",
      "primary_command": "desloppify plan resolve \"review::.::holistic::test_strategy::frontend_has_no_test_harness\" --note \"<what you did>\" --confirm",
