# --- Sheshi .NET API ---
ConnectionStrings__Default=Host=localhost;Port=55432;Database=sheshi;Username=sheshi;Password=sheshi
Jwt__Issuer=https://sheshi.local
Jwt__Audience=sheshi-web
Jwt__SigningKey=CHANGE_ME_min_32_byte_random_secret_value_here
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30
Database__AutoMigrate=false
# Lock to your real host(s) in production (Host-header hardening); "*" is dev-only.
AllowedHosts=*
Cors__AllowedOrigins=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:8080,http://127.0.0.1:8080
Storage__UploadPath=./uploads
# In production use https and your real domain.
Storage__PublicBaseUrl=http://localhost:5080/uploads
Storage__MaxBytes=5242880
# DataProtection keys (protect refresh/confirm/reset tokens). Mount on a durable
# volume; losing them invalidates outstanding email-confirm/reset links.
DataProtection__KeyPath=./keys
RateLimits__AuthPerMinute=20
RateLimits__ReadsPerMinute=600
RateLimits__WritesPerMinute=90
RateLimits__RealtimeConnectsPerMinute=120
RateLimits__ModerationPerMinute=120
# Set true ONLY behind a trusted TLS-terminating reverse proxy: it then trusts
# X-Forwarded-* and the app skips its own HTTPS redirect (the proxy owns it).
LoadBalancer__UseForwardedHeaders=false
LoadBalancer__ForwardLimit=2
# Repeat with LoadBalancer__KnownProxies__1, etc. when running behind a trusted proxy.
LoadBalancer__KnownProxies__0=127.0.0.1
Smtp__Host=localhost
Smtp__Port=1025
Smtp__FromEmail=no-reply@sheshi.local
# Production SMTP usually needs TLS + credentials:
Smtp__EnableSsl=false
Smtp__Username=
Smtp__Password=
Frontend__BaseUrl=http://localhost:3001
# Optional local bootstrap account. Leave blank in production unless you intend
# to create or promote this exact account at startup.
SeedAdmin__Email=
SeedAdmin__Password=
SeedAdmin__DisplayName=Sheshi Admin
# OAuth (leave blank to disable a provider)
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=
Authentication__Microsoft__ClientId=
Authentication__Microsoft__ClientSecret=
Authentication__Apple__ClientId=
Authentication__Apple__TeamId=
Authentication__Apple__KeyId=
Authentication__Apple__PrivateKey=
# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:5080
