metadata_unencrypted:
  environment: production
  description: Copy to production.sops.yaml, replace every CHANGE_ME value, then encrypt with SOPS.

secrets:
  db_password: CHANGE_ME_GENERATED_BY_TEMPLATE_SCRIPT
  db_connection_string: Host=db;Port=5432;Database=sheshi;Username=sheshi;Password=CHANGE_ME_DB_PASSWORD
  jwt_signing_key: CHANGE_ME_64_BYTE_RANDOM_SECRET
  smtp_password: CHANGE_ME_SMTP_PASSWORD
  object_storage_access_key: CHANGE_ME_HETZNER_OBJECT_STORAGE_ACCESS_KEY
  object_storage_secret_key: CHANGE_ME_HETZNER_OBJECT_STORAGE_SECRET_KEY
  backup_encryption_key: CHANGE_ME_RESTIC_REPOSITORY_PASSWORD
