SHESHI_IMAGE_TAG=0000000000000000000000000000000000000000

# Runtime secret files expected under /opt/sheshi/secrets:
# db_password, db_connection_string, jwt_signing_key, smtp_password,
# object_storage_access_key, object_storage_secret_key,
# backup_storage_access_key, backup_storage_secret_key, backup_encryption_key

VITE_API_BASE_URL=https://api.sheshi.live
Jwt__Issuer=https://api.sheshi.live
Jwt__Audience=sheshi-web
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30
Frontend__BaseUrl=https://sheshi.live
Cors__AllowedOrigins=https://sheshi.live
AllowedHosts=sheshi.live;api.sheshi.live
Storage__Provider=s3
Storage__PublicBaseUrl=https://uploads.sheshi.live
Storage__MaxBytes=20971520
Storage__S3__Bucket=sheshi-live-uploads
Storage__S3__Endpoint=https://CHANGE_ME_R2_ACCOUNT_ID.r2.cloudflarestorage.com
Storage__S3__Region=auto
Storage__S3__ForcePathStyle=true
Smtp__Host=smtp.postmarkapp.com
Smtp__Port=587
Smtp__FromEmail=no-reply@sheshi.live
Smtp__Username=postmark-server-token
Smtp__EnableSsl=true
RESTIC_REPOSITORY=s3:https://CHANGE_ME_R2_ACCOUNT_ID.r2.cloudflarestorage.com/sheshi-live-backups
Authentication__Google__ClientId=
Authentication__Microsoft__ClientId=
Authentication__Apple__ClientId=
Authentication__Apple__TeamId=
Authentication__Apple__KeyId=
Authentication__Apple__PrivateKey=
SeedAdmin__Email=
SeedAdmin__Password=

# Error tracking (optional). Leave Sentry__Dsn blank to disable Sentry entirely (the app boots and runs
# fine without it). A Sentry DSN is a send-only ingestion endpoint, not a read credential. Set
# Sentry__Release to the deployed commit SHA so events are tagged with the release.
Sentry__Dsn=
Sentry__Release=
